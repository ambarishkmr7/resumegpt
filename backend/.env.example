# Database — MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=resumegpt_db
DB_USER=root
DB_PASSWORD=

# Or use a full URL (overrides DB_* settings above):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/resumegpt_db?charset=utf8mb4

# For SQLite (no MySQL needed — good for quick testing):
# DATABASE_URL=sqlite:///./storage/app.db

# Security
SECRET_KEY=change_me_use_openssl_rand_hex_32_for_production

# Admin user (auto-created on startup)
ADMIN_EMAIL=admin@resumegpt.com
ADMIN_PASSWORD=Admin@123

# Storage — "local" for filesystem, "s3" for Cloudflare R2 / AWS S3
STORAGE_BACKEND=local
# S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com   # Cloudflare R2
# S3_ENDPOINT_URL=                                                   # AWS S3 (empty = default)
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=resumegpt
# S3_REGION=auto                                                     # R2: "auto" | AWS: e.g. "us-east-1"

# Frontend CORS
FRONTEND_ORIGIN=http://localhost:5173

# AI (optional)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

GEMINI_API_KEY=
